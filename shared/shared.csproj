<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <LangVersion>9</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>Showdown.Shared</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="**/*.meta"/>
  </ItemGroup>

  <!-- 빌드 직후 DLL을 client/Assets/Plugins에 복사 -->
  <Target Name="DistributeShared" AfterTargets="Build">
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="$(MSBuildThisFileDirectory)../client/Assets/Plugins/" />
  </Target>

</Project>